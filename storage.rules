rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /invoices/{userId}/{allPaths=**} {
      // Allow users to upload and read their own invoices
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
